generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// User roles: student (limited) or admin (full control over problems).
enum Role {
  student
  admin
}

/// Difficulty levels for problems.
enum Difficulty {
  easy
  medium
  hard
}

/// Lifecycle states of a code submission.
enum SubmissionStatus {
  queued     // Waiting for an available worker
  running    // Currently being evaluated by a worker
  completed  // Finished correctly (might still have a 'Verdict' like WA)
  failed     // System-level failure during execution
  cancelled  // User aborted the submission
}

/// Whether the submission is a "Run" (public tests only) or "Submit" (final evaluation).
enum SubmissionKind {
  run
  submit
}

/// Final verdict for a code submission.
enum Verdict {
  AC  // Accepted (Passed all tests)
  WA  // Wrong Answer
  TLE // Time Limit Exceeded
  MLE // Memory Limit Exceeded
  RE  // Runtime Error
  CE  // Compilation Error
}

/// Represents a platform user.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(student)
  createdAt    DateTime @default(now()) @map("created_at")

  refreshTokens RefreshToken[]
  problems      Problem[]          @relation("ProblemAuthor")
  submissions   Submission[]
  leaderboard   LeaderboardEntry[]
}

/// Stores secure hashes of active refresh tokens to manage long-lived sessions.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash") // SHA-256 hash of the token
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// A coding challenge with a description, limits, and test cases.
model Problem {
  id            String     @id @default(uuid())
  slug          String     @unique // URL-friendly unique identifier (e.g. 'two-sum')
  title         String
  descriptionMd String     @map("description_md") // Problem statement in Markdown
  difficulty    Difficulty
  timeLimitMs   Int        @map("time_limit_ms")
  memoryLimitMb Int        @map("memory_limit_mb")
  authorId      String     @map("author_id")
  isPublished   Boolean    @default(false) @map("is_published")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  author      User              @relation("ProblemAuthor", fields: [authorId], references: [id])
  languages   ProblemLanguage[]
  testCases   TestCase[]
  submissions Submission[]
  leaderboard LeaderboardEntry[]
}

/// Multi-language support configuration for each problem.
model ProblemLanguage {
  problemId   String @map("problem_id")
  language    String // e.g., 'python', 'javascript'
  starterCode String @map("starter_code") // Boilerplate code provided to the user

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([problemId, language])
}

/// A specific input/output pair used to validate code correctness.
model TestCase {
  id             String @id @default(uuid())
  problemId      String @map("problem_id")
  isHidden       Boolean @default(true) @map("is_hidden") // Hidden tests are used only during "Submit"
  input          String
  expectedOutput String @map("expected_output")
  weight         Int    @default(1)
  orderIndex     Int    @map("order_index")

  problem           Problem                @relation(fields: [problemId], references: [id], onDelete: Cascade)
  submissionResults SubmissionTestResult[]

  @@index([problemId, orderIndex])
}

/// A code snippet sent by a user for evaluation.
model Submission {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  problemId    String           @map("problem_id")
  language     String
  sourceCode   String           @map("source_code")
  status       SubmissionStatus @default(queued)
  kind         SubmissionKind
  verdict      Verdict?
  totalTimeMs  Int?             @map("total_time_ms")
  maxMemoryKb  Int?             @map("max_memory_kb")
  judgeMessage String?          @map("judge_message") // Error logs or system messages
  createdAt    DateTime         @default(now()) @map("created_at")
  startedAt    DateTime?        @map("started_at")
  finishedAt   DateTime?        @map("finished_at")

  user        User                   @relation(fields: [userId], references: [id])
  problem     Problem                @relation(fields: [problemId], references: [id])
  testResults SubmissionTestResult[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([problemId, status, createdAt])
}

/// Detailed result of a submission running against a specific test case.
model SubmissionTestResult {
  id            String  @id @default(uuid())
  submissionId  String  @map("submission_id")
  testCaseId    String  @map("test_case_id")
  passed        Boolean
  timeMs        Int     @map("time_ms")
  memoryKb      Int     @map("memory_kb")
  stdoutPreview String? @map("stdout_preview") // Snippet of the actual program output
  stderrPreview String? @map("stderr_preview")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCase   TestCase   @relation(fields: [testCaseId], references: [id])

  @@unique([submissionId, testCaseId])
}

/// Stores the personal best historical performance for each user on each problem.
model LeaderboardEntry {
  problemId        String   @map("problem_id")
  userId           String   @map("user_id")
  bestTimeMs       Int      @map("best_time_ms")
  bestSubmissionId String   @map("best_submission_id")
  updatedAt        DateTime @updatedAt @map("updated_at")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([problemId, userId])
}

