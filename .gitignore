# ========================
# AlgoScheduler .gitignore
# ========================

# Dependencies (npm workspaces)
node_modules
.pnp
.pnp.js

# Lock file — excluded so Vercel generates a fresh Linux-compatible one
# (Windows lockfile omits @rollup/rollup-linux-x64-gnu optional dependency)
package-lock.json

# Build Artifacts (TypeScript compiled output)
dist
.next
.turbo
out
build

# TypeScript incremental build cache
*.tsbuildinfo

# Database (local SQLite files for dev, if any)
/packages/db/prisma/*.db
/packages/db/prisma/*.db-journal

# Environment Secrets (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor & System Files
.vscode
.idea
.DS_Store
Thumbs.db
*.swp

# Testing
coverage
.nyc_output

# Deployment Caches
.vercel

# AI/IDE Metadata
.gemini

# Generated OpenAPI Spec (regenerated on build)
openapi/openapi.json
