# --- DATABASE ---
# Production PostgreSQL connection string
# Example: postgresql://user:password@postgres:5432/projectdb?schema=public
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/projectdb?schema=public"

# --- REDIS / QUEUE ---
# Redis connection string for BullMQ
# Example: redis://redis:6379
REDIS_URL="redis://redis:6379"

# --- SECURITY ---
# Long, random strings for JWT signing (at least 32 chars)
JWT_ACCESS_SECRET="change_this_to_a_very_long_random_string_123"
JWT_REFRESH_SECRET="change_this_to_another_very_long_random_string_456"

# --- API CONFIG ---
NODE_ENV="production"
API_HOST="0.0.0.0"
API_PORT=3001

# --- CORS / FRONTEND ---
# Comma-separated list of allowed origins
# In production, this should be your domain (e.g., https://yourdomain.com)
CORS_ORIGIN="http://localhost"

# --- FRONTEND BUILD ---
# Only needed during build time if the frontend is served from a different domain
# For the Docker Compose setup, Nginx reverse proxies /api so this is usually just "/api"
VITE_API_BASE_URL="/api"
